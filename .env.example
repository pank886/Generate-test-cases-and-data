# ============================================================
# 智能测试助手 — 环境变量模板
# 复制为 .env 后修改对应值即可启动
# ============================================================

# ============================================================
# 必填配置
# ============================================================

# Embedding 模型（Ollama 必需，启动时校验为空会报错）
EMBEDDING_MODEL=bge-m3
EMBEDDING_URL=http://localhost:11434
# EMBEDDING_TIMEOUT=180  # CPU 模式建议 180s+

# ============================================================
# LLM — 优先使用 DeepSeek，其次本地模型（自动降级）
# ============================================================

# ---- DeepSeek API（推荐） ----
DEEP_URL=https://api.deepseek.com
DEEP_API_KEY=sk-your-key-here
DEEP_MODEL=deepseek-v4-pro

# ---- 本地 LLM（DeepSeek 三个参数任一缺失时自动降级） ----
# LLM_MODEL=qwen2.5:14b
# LLM_API_KEY=sk-no-auth
# LLM_BASE_URL=http://localhost:11434/v1
#   ↑ 兼容旧变量名 LANGCHAIN_URL，两者等价，LLM_BASE_URL 优先

# ---- LLM 通用参数 ----
# LLM_TEMPERATURE=0.4          # 0=确定性, 1=随机, 建议 0.3~0.5
# MAX_RETRIES=2                # 结构化输出校验失败重试次数

# ============================================================
# 功能开关
# ============================================================

# 深度思考模式（true: 测试点分析/Excel计划等节点启用 thinking）
ENABLE_THINKING=true

# ============================================================
# 文本切分与检索
# ============================================================

# CHUNK_SIZE=1000              # 文本块最大字符数 (100~8000)
# CHUNK_OVERLAP=200            # 相邻块重叠字符数 (0~2000)
# RETRIEVAL_K=50               # 向量检索返回块数 (1~200)

# ============================================================
# 文档摄取
# ============================================================

# MAX_INGEST_CHARS_PER_BATCH=30000   # 接口文档 LLM 单批最大字符数 (5000~100000)
# COMMON_SERVICE_MODULE=公共基础服务   # Hop 2b 检索时追加的通用模块名

# ============================================================
# ChromaDB 向量库
# ============================================================

# CHROMA_DB_DIR=./vector_store/chroma_db
# COLLECTION_PRODUCT_DOCS=product_docs
# COLLECTION_API_DEFS=api_defs

# ============================================================
# Excel / YAML 生成
# ============================================================

# EXCEL_REPAIR_ATTEMPTS=3      # Excel 校验失败自动修复最大次数 (1~10)
# YAML_CONCURRENCY=5           # YAML 并发生成线程数 (1~20)
# YAML_REPAIR_ROUNDS=1         # YAML 修复轮数：全量轮之外的自查重生成轮数 (0~3)
#                              # 失败项登记后集中送思考节点自查重生成；
#                              # 超轮次仍失败 → 计 failed + _generation_errors.json，不写占位文件

# ============================================================
# Web 服务
# ============================================================

# WEB_HOST=0.0.0.0
# WEB_PORT=8000
# UPLOAD_MAX_SIZE_MB=100       # 单文件上传上限 MB (1~1024)

# ============================================================
# 后台任务
# ============================================================

# TASK_MAX_WORKERS=10          # 后台线程池大小 (1~50)
# TASK_MAX_QUEUE=30            # 后台任务队列上限 (1~200)
# WORKFLOW_SESSION_TTL=1800    # Phase C 会话超时秒数 (60~86400)
# TASK_TTL_SECONDS=3600        # 任务状态保留时间，超时 GET /task/{id} 返回 404

# ============================================================
# 输出与日志
# ============================================================

# 测试用例输出目录 = PYCHARM_MISC / PYTEST_DATA_DIR（两者均必填，否则输出路径为空）
PYCHARM_MISC=D:\your\target\project\root
PYTEST_DATA_DIR=./testcase

# Phase B 生成计划时输出到该目录：test_plan.xlsx + translation_cache.json
# + api_defs.json（接口定义快照，Phase C 生成 YAML 的数据来源，缺失时确认计划将被阻断）

# LOG_DIR=./logs
# LOG_LEVEL=INFO               # DEBUG / INFO / WARNING / ERROR

# ============================================================
# 文件删除（ChromaDB 重试）
# ============================================================

# CHROMA_RETRY_DELAY=300       # ChromaDB 删除重试延迟秒数 (10~3600)

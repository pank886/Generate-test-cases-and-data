# ============================================================
# 必填配置
# ============================================================

# Embedding 模型（Ollama 必需）
EMBEDDING_MODEL=bge-m3
EMBEDDING_URL=http://localhost:11434

# ============================================================
# LLM — 优先使用 DeepSeek，其次本地模型
# ============================================================

# ---- DeepSeek API（推荐） ----
DEEP_URL=https://api.deepseek.com
DEEP_API_KEY=sk-your-key-here
DEEP_MODEL=deepseek-v4-pro

# ---- 本地 LLM（DeepSeek 未配置时自动降级使用） ----
# LLM_MODEL=qwen2.5:14b
# LLM_API_KEY=sk-no-auth
# LANGCHAIN_URL=http://localhost:11434/v1

# ============================================================
# 功能开关
# ============================================================

# 深度思考（true: 测试点分析/Excel计划等节点使用深度思考，false: 普通模式）
ENABLE_THINKING=true

# ============================================================
# 可选调优参数
# ============================================================

# 文本切分
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200

# 检索召回量
# RETRIEVAL_K=50

# 上传大小上限（MB）
# UPLOAD_MAX_SIZE_MB=100

# 后台线程池
# TASK_MAX_WORKERS=10
# TASK_MAX_QUEUE=30

# Phase C 会话超时（秒）
# WORKFLOW_SESSION_TTL=1800

# 输出路径
# TESTCASE_BASE=./testcase_out

# 日志
# LOG_LEVEL=INFO
